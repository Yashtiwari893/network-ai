## ⚙️ 9. getNextRecommendation — Core API (New Controller Function)

```javascript
// controller/flowController.js mein add karo

exports.getNextRecommendation = async (req, res) => {
  try {
    const { phone, category, excludeIds = [] } = req.body;
    if (!phone || !category) {
      return responseManager.onBadRequest("phone aur category required hain", res);
    }

    const primary = mongoConnection.useDb(constants.DEFAULT_DB);
    const User = primary.model(constants.MODELS.user, userModel);
    const ConnectionRequest = primary.model(constants.MODELS.connectionRequest, connectionRequestModel);
    const SeenRec = primary.model("seen_recommendations", seenRecommendationModel);
    const DailyLimit = primary.model("daily_limits", dailyLimitModel);

    // ── 1. Daily Limit Check ──────────────────────────────────────────
    const today = new Date().toISOString().split("T")[0]; // "2024-03-10"
    const limitDoc = await DailyLimit.findOne({ phone, date: today }).lean();
    if (limitDoc && limitDoc.count >= 5) {
      return responseManager.onSuccess("daily_limit_reached", {
        message: "Aaj ke 5 recommendations ho gaye hain! Kal dobara aayein. 🙏",
        dailyCount: limitDoc.count,
        isEnd: false
      }, res);
    }

    // ── 2. Get Seen Profile IDs ───────────────────────────────────────
    const seenDocs = await SeenRec.find({ viewerPhone: phone })
      .select("seenProfileId")
      .lean();
    const seenObjectIds = seenDocs.map(d => new mongoose.Types.ObjectId(d.seenProfileId));

    // ── 3. Get Sent Request Profile IDs ──────────────────────────────
    const sentRequests = await ConnectionRequest.find({
      senderPhone: phone,
      status: { $in: ["pending", "accepted"] }
    }).select("receiverPhone").lean();
    const sentPhones = sentRequests.map(r => r.receiverPhone).filter(Boolean);
    let sentUserIds = [];
    if (sentPhones.length > 0) {
      const sentUsers = await User.find({ phone: { $in: sentPhones } }).select("_id").lean();
      sentUserIds = sentUsers.map(u => new mongoose.Types.ObjectId(u._id));
    }

    // ── 4. Frontend excludeIds (chatbot se pass ho rahe IDs) ─────────
    const frontEndExcludeIds = Array.isArray(excludeIds)
      ? excludeIds
          .flatMap(id => String(id).split(","))
          .map(id => id.trim())
          .filter(id => mongoose.Types.ObjectId.isValid(id))
          .map(id => new mongoose.Types.ObjectId(id))
      : [];

    // ── 5. Merge ALL exclusions ────────────────────────────────────────
    const allExcludedSet = new Set([
      ...seenObjectIds.map(id => id.toString()),
      ...sentUserIds.map(id => id.toString()),
      ...frontEndExcludeIds.map(id => id.toString())
    ]);
    const allExcludedIds = [...allExcludedSet]
      .filter(id => mongoose.Types.ObjectId.isValid(id))
      .map(id => new mongoose.Types.ObjectId(id));

    // ── 6. Check if ALL recommendations exhausted ─────────────────────
    const totalAvailable = await User.countDocuments({
      consent: true,
      phone: { $ne: phone },
      category: { $in: [category] }
    });
    if (allExcludedIds.length >= totalAvailable) {
      return responseManager.onSuccess("no_more_recommendations", {
        message: "🙏 Thank You! Aap saare available profiles dekh chuke hain. Naye members join karne par aapko dobara recommend karenge.",
        isEnd: true
      }, res);
    }

    // ── 7. Get current user's bio_vector ──────────────────────────────
    const currentUser = await User.findOne({ phone }).select("bio_vector").lean();
    const queryVec = Array.isArray(currentUser?.bio_vector)
      ? currentUser.bio_vector.map(Number)
      : null;

    // ── 8. Vector Search ──────────────────────────────────────────────
    let result = null;
    if (queryVec && queryVec.length > 0) {
      const pipeline = [
        {
          $vectorSearch: {
            index: constants.VECTOR_INDEX,
            path: "bio_vector",
            queryVector: queryVec,
            numCandidates: 100,
            limit: 20
          }
        },
        {
          $match: {
            _id: { $nin: allExcludedIds },
            consent: true,
            phone: { $ne: phone },
            category: { $in: [category] }
          }
        },
        { $limit: 1 },
        {
          $project: {
            name: 1, company_name: 1, phone: 1,
            bio: 1, link1: 1, link2: 1, category: 1
          }
        }
      ];
      const results = await User.aggregate(pipeline);
      result = results[0] || null;
    }

    // ── 9. Fallback: Random if vector search fails ────────────────────
    if (!result) {
      result = await User.findOne({
        _id: { $nin: allExcludedIds },
        consent: true,
        phone: { $ne: phone },
        category: { $in: [category] }
      })
        .sort({ searchCount: 1 })
        .select("name company_name phone bio link1 link2 category")
        .lean();
    }

    // ── 10. Still no result — truly exhausted ────────────────────────
    if (!result) {
      return responseManager.onSuccess("no_more_recommendations", {
        message: "🙏 Thank You! Aap saare available profiles dekh chuke hain.",
        isEnd: true
      }, res);
    }

    // ── 11. Mark as Seen ──────────────────────────────────────────────
    await SeenRec.findOneAndUpdate(
      { viewerPhone: phone, seenProfileId: result._id },
      {
        $setOnInsert: {
          viewerPhone: phone,
          seenProfileId: result._id,
          seenProfilePhone: result.phone,
          category,
          seenAt: new Date()
        }
      },
      { upsert: true, new: true }
    );

    // ── 12. Increment Daily Limit ─────────────────────────────────────
    await DailyLimit.findOneAndUpdate(
      { phone, date: today },
      { $inc: { count: 1 } },
      { upsert: true, new: true }
    );

    // ── 13. Increment profile's searchCount ──────────────────────────
    await User.updateOne({ _id: result._id }, { $inc: { searchCount: 1 } });

    // ── 14. Log to Google Sheet ───────────────────────────────────────
    await logToGoogleSheet("SEEN_RECOMMENDATION", {
      viewerPhone: phone,
      seenProfilePhone: result.phone,
      category,
      timestamp: new Date().toISOString()
    });

    return responseManager.onSuccess("recommendation_found", {
      recommendation: result,
      isEnd: false
    }, res);

  } catch (error) {
    console.error("[getNextRecommendation] Error:", error);
    return responseManager.internalServer(error, res);
  }
};
```

