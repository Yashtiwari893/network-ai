## 🔄 5. Connection Request Status Management

### 5.1 Status Lifecycle

```
User A sends request
        │
        ▼
[status: "pending"] ──→ 11za template → User B ko notification
        │
   User B responds
   ┌────┴────┐
   ▼         ▼
[accepted] [rejected]
   │
   ▼
User A ko confirmation template
```

### 5.2 API Functions

```javascript
// ── Send Connection Request ──────────────────────────────────────────
exports.sendConnectionRequest = async (req, res) => {
  const { senderPhone, receiverPhone } = req.body;
  const primary = mongoConnection.useDb(constants.DEFAULT_DB);
  const ConnectionRequest = primary.model(constants.MODELS.connectionRequest, connectionRequestModel);

  // Duplicate check
  const existing = await ConnectionRequest.findOne({ senderPhone, receiverPhone });
  if (existing) {
    return responseManager.onBadRequest("Request already sent", res);
  }

  // MongoDB mein insert
  const request = await ConnectionRequest.create({
    senderPhone,
    receiverPhone,
    status: "pending"
  });

  // Google Sheet mein log karo
  await logToGoogleSheet("CONNECTION_REQUEST", {
    senderPhone, receiverPhone,
    status: "pending",
    requestId: request._id.toString(),
    timestamp: new Date().toISOString()
  });

  // 11za template — User B ko notification
  const templateMsgId = await send11zaTemplate({
    to: receiverPhone,
    template: "ivy_connection_request",  // tumhara existing template name
    params: { senderName: senderPhone }
  });

  // templateMessageId save karo
  await ConnectionRequest.updateOne(
    { _id: request._id },
    { $set: { templateMessageId: templateMsgId } }
  );

  return responseManager.onSuccess("Connection request sent", request, res);
};

// ── Accept Connection Request ────────────────────────────────────────
exports.acceptConnectionRequest = async (req, res) => {
  const { senderPhone, receiverPhone } = req.body;
  const primary = mongoConnection.useDb(constants.DEFAULT_DB);
  const ConnectionRequest = primary.model(constants.MODELS.connectionRequest, connectionRequestModel);

  const updated = await ConnectionRequest.findOneAndUpdate(
    { senderPhone, receiverPhone, status: "pending" },
    { $set: { status: "accepted", acceptedAt: new Date() } },
    { new: true }
  );

  if (!updated) {
    return responseManager.notFoundRequest("Request not found or already processed", res);
  }

  // Google Sheet update karo
  await logToGoogleSheet("REQUEST_ACCEPTED", {
    senderPhone, receiverPhone,
    status: "accepted",
    requestId: updated._id.toString(),
    acceptedAt: new Date().toISOString()
  });

  // 11za template — User A ko confirmation
  await send11zaTemplate({
    to: senderPhone,
    template: "ivy_request_accepted",
    params: { receiverName: receiverPhone }
  });

  return responseManager.onSuccess("Request accepted", updated, res);
};

// ── Reject Connection Request ────────────────────────────────────────
exports.rejectConnectionRequest = async (req, res) => {
  const { senderPhone, receiverPhone } = req.body;
  const primary = mongoConnection.useDb(constants.DEFAULT_DB);
  const ConnectionRequest = primary.model(constants.MODELS.connectionRequest, connectionRequestModel);

  const updated = await ConnectionRequest.findOneAndUpdate(
    { senderPhone, receiverPhone, status: "pending" },
    { $set: { status: "rejected", rejectedAt: new Date() } },
    { new: true }
  );

  // Google Sheet log
  await logToGoogleSheet("REQUEST_REJECTED", { senderPhone, receiverPhone, status: "rejected" });

  return responseManager.onSuccess("Request rejected", updated, res);
};
```

