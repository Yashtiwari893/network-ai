## 📋 6. Google Sheets Logging Integration

### 6.1 Logger Utility (Banana Hai)

```javascript
// utilities/googleSheetLogger.js
const { google } = require("googleapis");

const auth = new google.auth.GoogleAuth({
  credentials: JSON.parse(process.env.GOOGLE_SERVICE_ACCOUNT_JSON),
  scopes: ["https://www.googleapis.com/auth/spreadsheets"]
});

const SPREADSHEET_ID = process.env.GOOGLE_SHEET_ID;

// Sheet tabs mapping
const SHEETS = {
  SEEN_RECOMMENDATIONS: "SeenRecommendations",
  CONNECTION_REQUESTS: "ConnectionRequests",
  DAILY_LIMITS: "DailyLimits"
};

async function logToGoogleSheet(eventType, data) {
  try {
    const client = await auth.getClient();
    const sheets = google.sheets({ version: "v4", auth: client });

    let sheetName, row;

    switch (eventType) {
      case "SEEN_RECOMMENDATION":
        sheetName = SHEETS.SEEN_RECOMMENDATIONS;
        row = [data.viewerPhone, data.seenProfilePhone, data.category, data.timestamp];
        break;

      case "CONNECTION_REQUEST":
      case "REQUEST_ACCEPTED":
      case "REQUEST_REJECTED":
        sheetName = SHEETS.CONNECTION_REQUESTS;
        row = [data.senderPhone, data.receiverPhone, data.status, data.requestId, data.timestamp || new Date().toISOString()];
        break;

      case "DAILY_LIMIT_REACHED":
        sheetName = SHEETS.DAILY_LIMITS;
        row = [data.phone, data.date, data.count, data.timestamp];
        break;
    }

    await sheets.spreadsheets.values.append({
      spreadsheetId: SPREADSHEET_ID,
      range: `${sheetName}!A:Z`,
      valueInputOption: "USER_ENTERED",
      resource: { values: [row] }
    });

    console.log(`[GoogleSheet] ✅ Logged: ${eventType}`);
  } catch (err) {
    console.error(`[GoogleSheet] ❌ Failed to log ${eventType}:`, err.message);
    // Sheet fail ho toh bhi main flow nahi rukna chahiye — silent fail
  }
}

module.exports = { logToGoogleSheet };
```

### 6.2 Google Sheet Structure

| Sheet Tab | Columns |
|-----------|---------|
| `SeenRecommendations` | ViewerPhone \| SeenProfilePhone \| Category \| Timestamp |
| `ConnectionRequests` | SenderPhone \| ReceiverPhone \| Status \| RequestId \| Timestamp |
| `DailyLimits` | Phone \| Date \| Count \| Timestamp |

