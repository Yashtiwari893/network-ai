## 👁️ 4. Seen ID Tracking System — Full Implementation

### 4.1 Model File (Banana Hai)

```javascript
// models/seenRecommendation.model.js
const mongoose = require("mongoose");
const mongoosePaginate = require("mongoose-paginate-v2");

const schema = new mongoose.Schema(
  {
    viewerPhone:       { type: String, required: true, trim: true },
    seenProfileId:     { type: mongoose.Schema.Types.ObjectId, required: true, ref: "users" },
    seenProfilePhone:  { type: String, trim: true },
    category:          { type: String, trim: true },
    seenAt:            { type: Date, default: Date.now }
  },
  { timestamps: true, strict: false }
);

// CRITICAL: Duplicate prevent karne ke liye compound unique index
schema.index({ viewerPhone: 1, seenProfileId: 1 }, { unique: true });
schema.index({ viewerPhone: 1, category: 1 });
schema.index({ viewerPhone: 1, seenAt: 1 });

schema.plugin(mongoosePaginate);
module.exports = schema;
```

### 4.2 Tracking Flow (Controller mein)

```javascript
// Step A: Seen IDs fetch karo (query se exclude karne ke liye)
async function getSeenProfileIds(viewerPhone, primary) {
  const SeenRec = primary.model("seen_recommendations", seenRecommendationModel);
  const seenDocs = await SeenRec.find({ viewerPhone })
    .select("seenProfileId")
    .lean();
  return seenDocs.map(d => new mongoose.Types.ObjectId(d.seenProfileId));
}

// Step B: Recommendation show hone ke baad save karo
async function markAsSeen(viewerPhone, seenProfile, category, primary) {
  const SeenRec = primary.model("seen_recommendations", seenRecommendationModel);
  await SeenRec.findOneAndUpdate(
    { viewerPhone, seenProfileId: seenProfile._id },
    { 
      $setOnInsert: {
        viewerPhone,
        seenProfileId: seenProfile._id,
        seenProfilePhone: seenProfile.phone,
        category,
        seenAt: new Date()
      }
    },
    { upsert: true, new: true }
  );
}

// Step C: MongoDB query mein exclude karo
const pipeline = [
  {
    $vectorSearch: {
      index: constants.VECTOR_INDEX,
      path: "bio_vector",
      queryVector: queryVec,
      numCandidates: 100,
      limit: 20
    }
  },
  {
    $match: {
      _id: { $nin: allExcludedIds },     // ← Seen IDs yahan exclude honge
      consent: true,
      category: { $in: [requestedCategory] }
    }
  },
  { $limit: 1 },
  { $project: { name: 1, company_name: 1, phone: 1, bio: 1, link1: 1, link2: 1, category: 1 } }
];
```

